{
  "name": "aneko-novel",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,worker -c blue,magenta \"npm run dev:client\" \"npm run dev:worker\"",
    "dev:worker": "wrangler dev",
    "dev:client": "vite",
    "build": "npm run build:client",
    "build:client": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "init-data": "wrangler dev --remote --test-scheduled && curl http://localhost:8787/api/init"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.0",
    "lucide-vue-next": "^0.379.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240605.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vue-tsc": "^2.0.0",
    "wrangler": "^3.60.0"
  }
}
